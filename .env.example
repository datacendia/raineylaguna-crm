# Postgres connection string. Required.
DATABASE_URL=postgres://user:pass@localhost:5432/raineylaguna_crm

# Redis connection string for BullMQ. Required for the outreach worker.
REDIS_URL=redis://localhost:6379

# --- Auth (multi-user, DB-backed) ---

# 32+ random bytes. Used to sign the auth cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
CRM_COOKIE_SECRET=

# Admin users are stored in the admin_users table. Create the first user with:
#   npx tsx scripts/user-create.ts admin@example.com "Your Name" your-password

# DEPRECATED — CRM_PASSWORD_HASH is no longer used. Remove from Railway env
# once multi-user auth is deployed and the migration has run.

# --- Public lead intake (raineylaguna-next → CRM) ---

# Shared secret with raineylaguna-next CRM_LEAD_INTAKE_SECRET.
# Must match across both Railway environments.
CRM_LEAD_INTAKE_SECRET=change_me_to_a_long_random_string

# --- AI-drafted outreach (Anthropic) ---

# Required for /api/leads/[id]/draft-outreach and the draft-outreach cron.
ANTHROPIC_API_KEY=

# Optional override. Defaults to claude-3-5-sonnet-20241022.
ANTHROPIC_MODEL=

# --- Draft-outreach cron tuning ---
DRAFT_CRON_MAX_LEADS=25
DRAFT_CRON_MIN_AGE_DAYS=7
DRAFT_CRON_DRY_RUN=false

# --- Twilio (outreach worker WhatsApp send) ---
# Without all four below, the outreach worker leaves WhatsApp events as
# 'Pending' with a note explaining the missing config. With them set, the
# worker sends via Twilio and marks events Sent.
#
# TWILIO_TEMPLATE_SID is required for production outbound to leads (no
# 24h customer-initiated window). Apply for template approval at Meta
# before going live; allow 5–10 days.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_TEMPLATE_SID=

# --- Email outreach (Resend) ---
# Without both, the dispatcher leaves Email events 'Pending' (degraded mode).
# RESEND_FROM must be a verified sender, e.g. "Rainey Laguna <hola@raineylaguna.com>".
RESEND_API_KEY=
RESEND_FROM=

# --- Outreach delivery / reply tracking ---
# Public https origin, used to build the Twilio StatusCallback URL.
CRM_PUBLIC_BASE_URL=https://crm.raineylaguna.com
# Shared secret echoed in the StatusCallback path; the webhook 401s without it.
TWILIO_STATUS_CALLBACK_TOKEN=
# Shared secret for the inbound-email webhook (Cloudflare Email Worker → CRM).
CRM_INBOUND_EMAIL_SECRET=

# --- Sereno (vigia) customer cross-reference sync ---
# Read-only vigia endpoint returning customer emails, plus its bearer secret.
VIGIA_CUSTOMERS_URL=
VIGIA_SYNC_SECRET=

# --- Digest auto-email cron (npm run digest-email) ---
# Comma-separated recipients for the Monday digest email. DIGEST_DRY_RUN=true
# renders + logs without sending.
DIGEST_EMAIL_TO=
DIGEST_DRY_RUN=false

# --- Priority-score weight overrides (optional) ---
# Partial JSON deep-merged over DEFAULT_WEIGHTS in src/lib/priority-score.ts.
# Server-only (digest/cron/APIs honour it; the client list uses defaults).
# e.g. {"niche":{"weights":{"Fitness":26}},"bands":{"critico":80}}
CRM_PRIORITY_WEIGHTS=

# --- Build / runtime metadata ---
# Deployed git SHA surfaced by /api/health as `version`. On Railway, leave
# unset — RAILWAY_GIT_COMMIT_SHA is injected automatically for repo-linked
# services and is used as the fallback.
NEXT_PUBLIC_GIT_SHA=
