# Postgres connection string. Required.
DATABASE_URL=postgres://user:pass@localhost:5432/raineylaguna_crm

# Redis connection string for BullMQ. Required for the outreach worker.
REDIS_URL=redis://localhost:6379

# --- Auth (single-password operator gate, Phase 1) ---

# bcrypt hash of the operator password. Generate with:
#   node -e "import('bcryptjs').then(b => console.log(b.hashSync(process.argv[1], 10)))" "your-password"
CRM_PASSWORD_HASH=

# 32+ random bytes. Used to sign the auth cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
CRM_COOKIE_SECRET=

# --- Public lead intake (raineylaguna-next → CRM) ---

# Shared secret with raineylaguna-next CRM_LEAD_INTAKE_SECRET.
# Must match across both Railway environments.
CRM_LEAD_INTAKE_SECRET=change_me_to_a_long_random_string

# --- AI-drafted outreach (Anthropic) ---

# Required for /api/leads/[id]/draft-outreach and the draft-outreach cron.
ANTHROPIC_API_KEY=

# Optional override. Defaults to claude-3-5-sonnet-20241022.
ANTHROPIC_MODEL=

# --- Draft-outreach cron tuning ---
DRAFT_CRON_MAX_LEADS=25
DRAFT_CRON_MIN_AGE_DAYS=7
DRAFT_CRON_DRY_RUN=false

# --- Twilio (outreach worker WhatsApp send) ---
# Without all four below, the outreach worker leaves WhatsApp events as
# 'Pending' with a note explaining the missing config. With them set, the
# worker sends via Twilio and marks events Sent.
#
# TWILIO_TEMPLATE_SID is required for production outbound to leads (no
# 24h customer-initiated window). Apply for template approval at Meta
# before going live; allow 5–10 days.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_TEMPLATE_SID=
